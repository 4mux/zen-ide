#!/bin/bash
# AppRun — entry point for the Zen IDE AppImage
# Sets up environment paths so the bundled GTK4/GI libraries are found.

HERE="$(dirname "$(readlink -f "$0")")"
APPDIR="${HERE}"

# GObject Introspection typelibs
export GI_TYPELIB_PATH="${APPDIR}/usr/lib/girepository-1.0:${APPDIR}/lib/girepository-1.0:${APPDIR}/gi_typelibs:${GI_TYPELIB_PATH}"

# Shared libraries
export LD_LIBRARY_PATH="${APPDIR}/usr/lib:${APPDIR}/lib:${LD_LIBRARY_PATH}"

# GSettings schemas
export GSETTINGS_SCHEMA_DIR="${APPDIR}/share/glib-2.0/schemas:${GSETTINGS_SCHEMA_DIR}"

# XDG data (icons, themes, mime)
export XDG_DATA_DIRS="${APPDIR}/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

# GdkPixbuf loaders
if [ -d "${APPDIR}/lib/gdk-pixbuf-2.0" ]; then
    export GDK_PIXBUF_MODULE_DIR="${APPDIR}/lib/gdk-pixbuf-2.0/2.10.0/loaders"
    export GDK_PIXBUF_MODULEDIR="${APPDIR}/lib/gdk-pixbuf-2.0/2.10.0/loaders"
fi

# Pango modules
if [ -d "${APPDIR}/lib/pango" ]; then
    export PANGO_LIBDIR="${APPDIR}/lib"
fi

# Disable GLib filesystem monitoring (not needed, avoids inotify issues)
export GIO_USE_FILE_MONITOR=noop 2>/dev/null || true

exec "${APPDIR}/zen-ide/zen-ide" "$@"
